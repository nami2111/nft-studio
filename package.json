{
	"name": "nft-studio",
	"version": "0.5.5",
	"private": true,
	"scripts": {
		"dev": "vite dev",
		"build": "tsc --noEmit && vite build && npm run postbuild",
		"postbuild": "node scripts/remove-comments.js",
		"prepare": "svelte-kit sync",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"standardize-comments": "node scripts/standardize-comments.js",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"postinstall:copy-auth": "node -e \"require('fs').cpSync('node_modules/@junobuild/core/dist/workers/', './static/workers', {recursive: true});\"",
		"postinstall": "npm run postinstall:copy-auth",
		"verify-lockfile": "bash ./scripts/verify-lockfile.sh",
		"verify-lock": "npm run verify-lockfile",
		"verify-lockfile-ci": "bash ./scripts/verify-lockfile.sh",
		"lint-ci": "npm run lint",
		"test:ci": "vitest run --reporter=junit --outdir .svelte-kit/test-results"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@internationalized/date": "^3.12.0",
		"@junobuild/config": "^2.14.1",
		"@junobuild/vite-plugin": "^4.7.0",
		"@lucide/svelte": "^0.577.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/enhanced-img": "^0.10.4",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/postcss": "^4.2.1",
		"@tailwindcss/vite": "^4.2.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@types/eslint": "^9.6.1",
		"@types/node": "^25.5.0",
		"@vite-pwa/sveltekit": "^1.1.0",
		"@vitest/coverage-v8": "^4.1.0",
		"clsx": "^2.1.1",
		"dompurify": "^3.3.3",
		"eslint": "^10.0.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.15.2",
		"globals": "^17.4.0",
		"jsdom": "^28.1.0",
		"mode-watcher": "^1.1.0",
		"postcss": "^8.5.8",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"rollup-plugin-visualizer": "^7.0.1",
		"svelte": "^5.53.12",
		"svelte-check": "^4.4.5",
		"svelte-sonner": "^1.1.0",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.1",
		"tslib": "^2.8.1",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.0",
		"vite": "^8.0.0",
		"vite-plugin-pwa": "^1.2.0",
		"vitest": "^4.1.0"
	},
	"type": "module",
	"overrides": {
		"cookie": "^0.7.0",
		"@neobr/svelte": {
			"@neobr/tailwind-preset": "npm:@neobr/tailwind-preset@1.0.4"
		}
	},
	"pnpm": {
		"overrides": {
			"@neobr/svelte>@neobr/tailwind-preset": "npm:@neobr/tailwind-preset@1.0.4"
		},
		"onlyBuiltDependencies": [
			"@hugeicons/svelte"
		]
	},
	"dependencies": {
		"@junobuild/analytics": "^0.2.11",
		"@junobuild/core": "^5.2.1",
		"@junobuild/functions": "^0.7.1",
		"@neobr/svelte": "^1.0.11",
		"@neobr/tailwind-preset": "^1.0.4",
		"@zip.js/zip.js": "^2.8.23",
		"bits-ui": "^2.16.3",
		"class-variance-authority": "^0.7.1",
		"idb": "^8.0.3",
		"jszip": "^3.10.1",
		"svelte-dnd-action": "^0.9.69",
		"zod": "^4.3.6"
	}
}
